# Klucz API OpenAI (wymagany do generowania scenariuszy i TTS)
OPENAI_API_KEY=sk-...

# Katalog z plikami Markdown (domyślnie: md w katalogu projektu)
# INPUT_DIR=md

# Katalog wyjściowy (domyślnie: output w katalogu projektu)
# OUTPUT_DIR=output

# Model do generowania scenariusza (Chat Completions)
# SCRIPT_MODEL=gpt-4o-mini

# Model i głos TTS (zalecane: cedar lub marin – lepsza jakość; onyx/echo bywają bardziej robotyczne)
# TTS_MODEL=gpt-4o-mini-tts
# TTS_VOICE=cedar

# Maks. znaków na jeden chunk TTS (długie odcinki dzielone na części)
# MAX_SCRIPT_CHARS_PER_CHUNK=4000

# Generowanie skryptu: ile sekcji w jednym wywołaniu (2 = lepsze zachowanie szczegółów 1:1)
# SECTIONS_PER_BATCH=2
# Min. stosunek długości skryptu do źródła (0.6 ≈ treść prawie 1:1; poniżej = rozbudowa)
# MIN_SCRIPT_TO_SOURCE_RATIO=0.6
# Po każdej partii: porównaj scenariusz ze źródłem i dopisz brakujące (0 = wyłącz)
# CHECK_COMPLETENESS_AFTER_BATCH=1
# Drugie przejście (Draft + uzupełnienie): po złożeniu całego scenariusza porównaj ze źródłem i dopisz brakujące (0 = wyłącz)
# FILL_MISSING_FULL_PASS=1

# Poziom logowania: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
